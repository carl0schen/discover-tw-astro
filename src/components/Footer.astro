---
import siteData from '../data/siteData.json';
const { nav, site } = siteData;
---

<footer class="bg-[#15141a] text-gray-400 pt-12 pb-8 border-t border-gray-800">
  <div class="container mx-auto px-6 max-w-[1400px]">

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12 mb-10 md:mb-12">

      <div class="lg:col-span-2">
        <a href="/" class="text-2xl font-bold text-white tracking-widest hover:text-gray-400 transition-colors inline-block mb-4">
          {nav.brand}
        </a>
        <p class="text-sm text-gray-500 leading-relaxed max-w-sm">
          {site.description}
        </p>
      </div>

      <div>
        <h4 class="text-white text-lg font-semibold mb-4">Quick Links</h4>
        <ul class="space-y-3 text-sm">
          <li><a href="#gallery" class="hover:text-white transition-colors">Gallery</a></li>
          <li><a href="#media" class="hover:text-white transition-colors">Media</a></li>
          <li><a href="#faq" class="hover:text-white transition-colors">FAQ</a></li>
          <li><a href="#news" class="hover:text-white transition-colors">News</a></li>
          <li><a href="#links" class="hover:text-white transition-colors">Useful Links</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-white text-lg font-semibold mb-4">Connect</h4>
        <ul class="space-y-3 text-sm">
          <li>
            <a href="https://github.com/carl0schen/discover-tw-astro" target="_blank" rel="noopener noreferrer" class="flex items-center hover:text-white transition-colors group">
              <svg class="w-5 h-5 mr-2 fill-current text-gray-400 group-hover:text-white transition-colors" viewBox="0 0 24 24">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.379.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.418 22 12c0-5.523-4.477-10-10-10z"></path>
              </svg>
              <span>GitHub</span>
            </a>
          </li>
          </ul>
      </div>

    </div>

    <div class="pt-8 border-t border-gray-800 flex flex-col md:flex-row justify-between items-center gap-4 text-xs md:text-sm">

      <p class="tracking-wider text-center md:text-left">
        &copy; <span id="currentYear"></span> {nav.brand}
      </p>

      <p class="text-gray-500 text-center md:text-right">
        Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors">Astro</a> &amp; Tailwind CSS
      </p>

    </div>

  </div>
</footer>

<script>
  // 自動更新年份
  const yearElement = document.getElementById('currentYear');
  if (yearElement) {
    yearElement.textContent = new Date().getFullYear().toString();
  }
</script>
