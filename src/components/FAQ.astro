---
const faqFiles = import.meta.glob('../content/faq/*.md', { eager: true });
const faqs = Object.values(faqFiles).sort((a: any, b: any) => a.frontmatter.order - b.frontmatter.order);
---

<section id="faq" class="py-10 md:py-16 bg-white">
  <div class="container mx-auto px-6 max-w-3xl">

    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
    </div>

    <div class="space-y-2">

      {faqs.map((faq: any) => {
        const { title } = faq.frontmatter;
        const Content = faq.Content;

        return (
          <div class="border-b border-gray-200 faq-item">

            <button class="faq-button flex w-full items-center justify-between py-6 text-left cursor-pointer outline-none hover:text-blue-600 transition-colors touch-manipulation select-none">
              <h3 class="text-xl font-semibold text-gray-900 current-color">{title}</h3>

              <span class="faq-icon ml-6 flex-shrink-0 transition-transform duration-300 ease-in-out">
                <svg class="w-6 h-6 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </span>
            </button>

            <div class="faq-content overflow-hidden will-change-[height] transform-gpu" style="height: 0px; display: none;">
              <div class="pb-6 flex flex-col prose prose-blue text-gray-600 max-w-none">
                <Content />
              </div>
            </div>

          </div>
        );
      })}

    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const faqItems = document.querySelectorAll('.faq-item');

    faqItems.forEach(item => {
      const button = item.querySelector('.faq-button');
      const content = item.querySelector('.faq-content') as HTMLElement;
      const icon = item.querySelector('.faq-icon');

      if (!button || !content || !icon) return;

      button.addEventListener('click', () => {
        const isClosed = content.style.height === '0px' || content.style.display === 'none';

        if (isClosed) {
          // 準備展開
          content.style.display = 'block';
          content.style.height = '0px';

          const targetHeight = content.scrollHeight + 'px';

          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              content.style.transition = 'height 300ms cubic-bezier(0.4, 0, 0.2, 1)';
              content.style.height = targetHeight;
              icon.classList.add('-rotate-180');
            });
          });

          content.addEventListener('transitionend', function handler(e) {
            if (e.propertyName === 'height' && content.style.height !== '0px') {
              content.style.height = 'auto';
              content.removeEventListener('transitionend', handler);
            }
          });

        } else {
          // 準備收合
          content.style.height = content.scrollHeight + 'px';

          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              content.style.transition = 'height 300ms cubic-bezier(0.4, 0, 0.2, 1)';
              content.style.height = '0px';
              icon.classList.remove('-rotate-180');
            });
          });

          content.addEventListener('transitionend', function handler(e) {
            if (e.propertyName === 'height' && content.style.height === '0px') {
              content.style.display = 'none';
              content.removeEventListener('transitionend', handler);
            }
          });
        }
      });
    });
  });
</script>
