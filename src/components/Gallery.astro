---
import { Image, getImage } from 'astro:assets';
import siteData from '../data/siteData.json';

const { gallery } = siteData;
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/gallery/*.{jpeg,jpg,png,gif,webp}');
---

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.css" />

<section id="gallery" class="py-10 md:py-16 bg-white relative">
  <div class="container mx-auto px-6 max-w-[1400px]">

    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Gallery</h2>
      <p class="text-lg text-gray-500">Explore the beauty of Taiwan through our lens.</p>
    </div>

    <div class="grid grid-cols-12 gap-2 md:gap-2">

      {gallery.map(async (item, index) => {
        const imagePath = `/src/assets/gallery/${item.image}`;
        if (!images[imagePath]) throw new Error(`找不到圖片: ${imagePath}`);
        const { default: myImage } = await images[imagePath]();

        const optimizedLightboxImg = await getImage({
          src: myImage,
          width: 1920,
          format: 'webp'
        });

        const patternIndex = index % 5;
        let desktopSpan = (patternIndex === 0 || patternIndex === 1) ? 'lg:col-span-6' : 'lg:col-span-4';
        let responsiveClasses = `col-span-6 md:col-span-6 ${desktopSpan}`;

        return (
          <a
            href={optimizedLightboxImg.src}
            class={`relative block group overflow-hidden transition-shadow duration-300 aspect-[4/3] lg:aspect-[16/11] bg-gray-100 cursor-pointer ${responsiveClasses}`}
            data-fancybox="taiwan-photos" /* 改名！避開與 #gallery 的網址衝突 */
            data-caption={item.title}
          >

            <Image
              src={myImage}
              alt={item.title}
              width={1000}
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-in-out"
            />

            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-6">
              <h3 class="text-white text-lg lg:text-xl font-bold translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                {item.title}
              </h3>
            </div>

          </a>
        );
      })}

    </div>
  </div>
</section>

<script is:inline src="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.umd.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    Fancybox.bind('[data-fancybox="taiwan-photos"]', {
      // 徹底關閉 Hash 網址連動功能，防止跟導覽列打架
      Hash: false,
      Thumbs: false, // 關閉燈箱效果的照片縮圖預覽
      // 關閉預設的縮放進場，強制套用最穩定的「淡入淡出」
      Images: {
        zoom: false,
      },
      // 原生自帶的 UI 排版
      Toolbar: {
        display: {
          left: ["infobar"], // 左上角的數字計數器 (1 / 20)
          middle: [],
          right: ["close"],  // 右上角的關閉叉叉
        },
      },
    });
  });
</script>

<style is:global>
  /* 將燈箱背景改為純黑，與 Solo 一致 */
  .fancybox__backdrop {
    background: #000 !important;
  }

  /* 移除預設的四周留白，讓照片左右完全貼齊螢幕 */
  .fancybox__slide,
  .f-carousel__slide {
    padding: 0 !important;
  }

  /* 標題樣式復刻：半透明黑底、小字、置中 */
  .fancybox__caption {
    text-align: center;
  }
  .fancybox__caption .fancybox__caption__text {
    color: #fff;
    font-size: 15px;
    background-color: rgba(0, 0, 0, 0.6);
    padding: 8px 16px;
    border-radius: 4px;
    display: inline-block;
  }

  /* 保障手機版一定要顯示左右箭頭，加上您確認過最完美的圓底 */
  @media (max-width: 768px) {
    .f-button[data-carousel-prev],
    .f-button[data-carousel-next] {
      display: flex !important;
      background-color: rgba(0, 0, 0, 0.4) !important;
      border-radius: 50% !important;
      width: 44px !important;
      height: 44px !important;
      opacity: 1 !important;
    }
    /* 讓箭頭稍微貼近螢幕邊緣 */
    .f-button[data-carousel-prev] { left: 10px !important; }
    .f-button[data-carousel-next] { right: 10px !important; }
  }
</style>
