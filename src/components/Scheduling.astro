---
import siteData from '../data/siteData.json';
const { scheduling } = siteData;
---

<section id="scheduling" class="py-10 md:py-16 bg-gray-100">
  <div class="container mx-auto px-6 text-center max-w-4xl">

    <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
      {scheduling.title}
    </h2>

    <p class="text-lg text-gray-600 mb-10">
      {scheduling.subtitle}
    </p>

    <a
      href={scheduling.buttonLink}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block bg-[#ffc800] text-black font-bold text-lg px-5 py-2 rounded hover:bg-yellow-500 transition duration-300"
    >
      {scheduling.buttonLabel}
    </a>

  </div>
</section>
