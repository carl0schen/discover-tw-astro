---
import siteData from '../data/siteData.json';
const { contact } = siteData;

// 讀取環境變數。如果使用者沒設定，就給個提示字串防呆
const accessKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY || 'YOUR_ACCESS_KEY_HERE';
---

<section id="contact" class="py-10 md:py-16 bg-white">
  <div class="container mx-auto px-6 max-w-2xl">

    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">{contact.title}</h2>
      <p class="text-lg text-gray-500">{contact.description}</p>
    </div>

    <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="space-y-6">

      <input type="hidden" name="access_key" value={accessKey}>

      <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

      <div>
        <label for="name" class="block text-sm font-semibold text-gray-700 mb-2">Name <span class="text-red-500">*</span></label>
        <input type="text" id="name" name="name" placeholder="John Doe" required
          class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-colors">
      </div>

      <div>
        <label for="email" class="block text-sm font-semibold text-gray-700 mb-2">Email address <span class="text-red-500">*</span></label>
        <input type="email" id="email" name="email" placeholder="name@example.com" required
          class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-colors">
      </div>

      <div>
        <label for="message" class="block text-sm font-semibold text-gray-700 mb-2">Message <span class="text-red-500">*</span></label>
        <textarea id="message" name="message" rows="5" placeholder="Enter your message here" required
          class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-colors resize-y"></textarea>
      </div>

      <div>
        <button type="submit" id="submit-btn"
          class="bg-[#ffc800] text-black font-bold text-lg px-5 py-2 rounded hover:bg-yellow-500 transition-all duration-300">
          Send
        </button>
      </div>

      <div id="form-message" class="hidden mt-4 p-4 rounded-lg text-sm font-medium transition-opacity duration-500 opacity-100"></div>

    </form>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const formMessage = document.getElementById('form-message') as HTMLDivElement;

  if (form && submitBtn && formMessage) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // 改變按鈕狀態
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
      submitBtn.classList.add('opacity-70', 'cursor-not-allowed');

      // 重置訊息框
      formMessage.style.display = 'none';
      formMessage.className = 'mt-4 p-4 rounded-lg text-sm font-medium transition-opacity duration-500 opacity-100';

      const formData = new FormData(form);

      try {
        // Web3Forms 完美支援標準 fetch，不需使用 no-cors
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData
        });

        // 解析回傳的 JSON 確認狀態
        const data = await response.json();

        if (response.ok && data.success) {
          // 送出成功
          formMessage.textContent = '✓ Message sent successfully! Thank you for getting in touch.';
          formMessage.classList.add('bg-green-100', 'text-green-800', 'border', 'border-green-200');
          formMessage.style.display = 'block';
          form.reset();

          // 6 秒後淡出
          setTimeout(() => {
            formMessage.classList.remove('opacity-100');
            formMessage.classList.add('opacity-0');

            setTimeout(() => {
              formMessage.style.display = 'none';
            }, 500);
          }, 6000);

        } else {
          // 伺服器回傳失敗 (例如沒填寫必填欄位)
          formMessage.textContent = data.message || 'Submission failed. Please check the content or try again later.';
          formMessage.classList.add('bg-red-100', 'text-red-800', 'border', 'border-red-200');
          formMessage.style.display = 'block';
        }
      } catch (error) {
        // 網路斷線等嚴重錯誤
        formMessage.textContent = 'Network connection error. Please try again later.';
        formMessage.classList.add('bg-red-100', 'text-red-800', 'border', 'border-red-200');
        formMessage.style.display = 'block';
      } finally {
        // 恢復按鈕狀態
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send';
        submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
      }
    });
  }
</script>
