---
import { Image } from 'astro:assets';
import siteData from '../data/siteData.json';
const { Links } = siteData;

const linkImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/links/*.{jpeg,jpg,png,gif,webp}');
---

<section id="links" class="py-10 md:py-16 bg-gray-50">
  <div class="container mx-auto px-4 sm:px-6 max-w-[1400px]">

    <div class="text-center mb-8 md:mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-2 md:mb-4">Useful Links</h2>
      <p class="text-base md:text-lg text-gray-500">Official resources to help you plan your perfect Taiwan trip.</p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 sm:gap-4 lg:gap-6">

      {Links.map(async (link) => {
        let myImage;
        if (link.image) {
          const imagePath = `/src/assets/links/${link.image}`;
          if (linkImages[imagePath]) {
            myImage = (await linkImages[imagePath]()).default;
          }
        }

        return (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            // 讓卡片在手機版高度變矮、取消圓角變方正一點，電腦版維持高挑
            class="group border border-gray-200 rounded-xl sm:rounded-2xl overflow-hidden hover:shadow-lg transition-all duration-300 flex flex-col bg-white h-auto sm:h-full"
          >
            <div class="h-20 sm:h-32 w-full relative overflow-hidden bg-gray-100 border-b border-gray-100 flex-shrink-0">
              {myImage ? (
                // object-cover 會完美裁切，不會變形！
                <Image
                  src={myImage}
                  alt={link.title}
                  width={400}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center bg-gray-100 text-gray-300 group-hover:text-gray-400 transition-colors duration-300">
                  <svg class="w-8 h-8 sm:w-12 sm:h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>
                  </svg>
                </div>
              )}
            </div>

            <div class="p-3 sm:p-4 flex flex-col flex-grow bg-gray-50 group-hover:bg-[#ffe100] transition-colors duration-300">

              <h3 class="text-sm font-bold text-gray-900 leading-tight line-clamp-2 text-center sm:text-left">
                {link.title}
              </h3>

              <p class="hidden sm:block text-xs text-gray-500 flex-grow line-clamp-3 mt-2">
                {link.desc}
              </p>
            </div>
          </a>
        );
      })}

    </div>
  </div>
</section>
